<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.adr.kodi.fcast.youtube" name="Kodi FCast YouTube" version="0.1" provider-name="andrewramsay">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="plugin.video.youtube" version="7.4.1.1"/>
    </requires>
    <extension point="xbmc.service" library="service.py"/>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <license>MIT</license>
        <source>https://github.com/andrewramsay/kodi.fcast.youtube</source>
        <summary lang="en_US">Play YouTube videos on Kodi using FCast</summary>
        <description lang="en_US">Enables Kodi to act as an FCast receiver application for the purpose of streaming YouTube videos</description>
    </extension>
</addon>
